# Supabase API — encontrar em: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...sua-anon-key

# Supabase Database — encontrar em: Dashboard > Database > Connection String > Transaction Pooler (porta 6543)
# NUNCA expor ao cliente (sem prefixo NEXT_PUBLIC_)
DATABASE_URL=postgresql://postgres.xxx:senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
